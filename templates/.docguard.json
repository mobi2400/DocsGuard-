{
  "docs": ["./docs/**/*.md"],
  "ignore": [
    "**/*.test.*",
    "**/*.spec.*",
    "**/__tests__/**",
    "**/test/**",
    "**/tests/**",
    "**/__pycache__/**",
    "**/.pytest_cache/**",
    "**/node_modules/**",
    "**/.venv/**",
    "**/venv/**",
    "**/vendor/**"
  ],
  "severity": {
    "security": "block",
    "architecture": "warn",
    "api-contract": "warn",
    "naming": "warn",
    "style": "warn"
  },
  "priority": {},
  "llm": {
    "provider": "groq",
    "model": "llama-3.3-70b-versatile"
  },
  "retrieval": {
    "topK": 6,
    "minScore": 0.15
  },
  "timeoutMs": 5000
}
