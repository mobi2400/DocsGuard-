{
  "name": "@mobasshirkhan/docguard",
  "version": "0.1.0",
  "description": "Documentation-aware code guard for AI-assisted development. Blocks commits whose changes violate your project's documented rules.",
  "keywords": [
    "ai",
    "documentation",
    "git-hooks",
    "pre-commit",
    "code-review",
    "guardrails",
    "llm"
  ],
  "homepage": "https://github.com/mobi2400/DocsGuard-#readme",
  "bugs": {
    "url": "https://github.com/mobi2400/DocsGuard-/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mobi2400/DocsGuard-.git"
  },
  "license": "MIT",
  "author": "mobasshir khan",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "docguard": "dist/cli/index.js"
  },
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "groq-sdk": "^1.2.1",
    "mdast-util-to-string": "^4.0.0",
    "minimatch": "^10.2.5",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "simple-git": "^3.36.0",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=18.17"
  }
}
