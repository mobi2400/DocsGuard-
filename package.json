{
  "name": "docguard",
  "version": "0.1.0",
  "description": "Documentation-aware code guard for AI-assisted development. Blocks commits whose changes violate your project's documented rules.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "docguard": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "documentation",
    "git-hooks",
    "pre-commit",
    "code-review",
    "guardrails",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "mdast-util-to-string": "^4.0.0",
    "minimatch": "^10.2.5",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "simple-git": "^3.36.0",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  }
}
